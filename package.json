{
  "name": "@stackctl/docker-storage-analyzer",
  "version": "1.0.1",
  "description": "Analyze Docker disk usage: images, containers, volumes, build cache, and logs",
  "type": "module",
  "bin": {
    "dkanalyze": "dist/cli/index.js"
  },
  "files": [
    "dist/analyzer",
    "dist/cli",
    "dist/web",
    "public",
    "README.md",
    "Dockerfile"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "bundle": "node build.mjs",
    "compile": "node build.mjs && npx pkg dist/bundle.cjs --targets node18-linux-x64 --output dist/dkanalyze",
    "compile:macos": "node build.mjs && npx pkg dist/bundle.cjs --targets node18-macos-x64 --output dist/dkanalyze-macos",
    "dev": "tsx src/cli/index.ts analyze",
    "start": "node dist/cli/index.js",
    "test": "vitest run",
    "lint": "tsc --noEmit",
    "web": "tsx src/web/server.ts"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "cli-table3": "^0.6.3",
    "commander": "^11.1.0",
    "dockerode": "^4.0.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "@types/dockerode": "^4.0.0",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "esbuild": "^0.28.1",
    "tsx": "^4.6.2",
    "typescript": "^5.3.2",
    "vitest": "^1.1.0"
  },
  "engines": {
    "node": ">=18"
  }
}
