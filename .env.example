# Docker
DOCKER_SOCKET=/var/run/docker.sock

# Web server
PORT=3000

# AI recommendations (optional — any one provider is enough)
# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Ollama (local)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3

# OpenCode (CLI-based, no API key needed)
# Just install opencode: npm i -g opencode
